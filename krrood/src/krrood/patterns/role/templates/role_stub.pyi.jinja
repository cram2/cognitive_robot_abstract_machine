{% for item in items %}
{% if item.__class__.__name__ == 'TypeVarInfo' %}
{{ item.source }}


{% elif item.__class__.__name__ in ['StubClassInfo', 'MixinInfo', 'SpecializedRoleForInfo'] %}
@dataclass({{ item.dataclass_args }})
class {{ item.name }}{% if item.bases %}({{ item.bases|join(', ') }}){% endif %}:
