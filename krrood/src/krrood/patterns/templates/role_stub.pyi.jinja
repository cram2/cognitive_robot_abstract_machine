from __future__ import annotations
from dataclasses import dataclass, field
from typing import TYPE_CHECKING
{% for import_statement in imports %}
{{ import_statement }}
{% endfor %}
{% if normal_module_imports %}
from .{{ module_name }} import {{ normal_module_imports|join(', ') }}
{% endif %}
{% if type_checking_module_imports %}
if TYPE_CHECKING:
    from .{{ module_name }} import {{ type_checking_module_imports|join(', ') }}
{% endif %}


{% for wrapped_class in stub_classes %}
@dataclass({{ wrapped_class.dataclass_args }})
class {{ wrapped_class.name }}({{ wrapped_class.bases|join(', ') }}):
    {% for wrapped_field in wrapped_class.fields %}
    {{ wrapped_field.name }}: {{ wrapped_field.type_name }}{{ wrapped_field.field_representation }}
    {% endfor %}
    {% if not wrapped_class.fields %}...{% endif %}


{% endfor %}
{% for taker_type, info in role_takers.items() %}
@dataclass
class {{ info.role_for_name }}({{ taker_type.__name__ }}):
    {{ info.taker_field_name }}: {{ taker_type.__name__ }}
    {% for wrapped_field in info.inherited_fields %}
    {{ wrapped_field.name }}: {{ wrapped_field.type_name }} = field(init=False)
    {% endfor %}


{% for role_info in info.roles %}
@dataclass({{ role_info.dataclass_args }})
class {{ role_info.name }}({{ info.role_for_name }}):
    # Original Owner of the {{ role_info.introduced_field.name }} field
    {{ role_info.introduced_field.name }}: {{ role_info.introduced_field.type_name }}{{ role_info.introduced_field.field_representation }}


{% endfor %}
{% endfor %}
