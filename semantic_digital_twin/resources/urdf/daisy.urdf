        <mesh filename="package://wpg_300_120_description/meshes/base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>
  <!-- Left finger joint -->
  <joint name="right_gripper_finger_joint" type="prismatic">
    <limit effort="5" lower="0" upper="0.06" velocity="0.05"/>
    <origin rpy="1.5708 0 -1.5708" xyz="0.042 0.0185 0.069"/>
    <parent link="right_gripper_base_link"/>
    <child link="right_gripper_left_finger_link"/>
    <axis xyz="0 0 1"/>
  </joint>
  <!-- Left finger -->
  <link name="right_gripper_left_finger_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
