    <parent link="right_wrist_3_link"/>
    <child link="right_adapter"/>
    <origin rpy="0 0 3.14" xyz="0 0 0.005"/>
  </joint>
  <!-- Base attachment -->
  <joint name="right_gripper_mount_joint" type="fixed">
    <origin rpy="0 0 -0.785" xyz="0 0 0"/>
    <parent link="right_adapter"/>
    <child link="right_gripper_base_link"/>
  </joint>
  <!-- Base link -->
  <link name="right_gripper_base_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
