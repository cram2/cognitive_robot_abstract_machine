      </geometry>
    </collision>
  </link>
  <!-- Right finger joint (mimics left finger) -->
  <joint name="right_gripper_right_finger_joint" type="prismatic">
    <mimic joint="right_gripper_finger_joint" multiplier="-1.0"/>
    <limit effort="5" lower="-0.06" upper="0" velocity="0.05"/>
    <origin rpy="1.5708 0 -1.5708" xyz="-0.042 -0.0185 0.069"/>
    <parent link="right_gripper_base_link"/>
    <child link="right_gripper_right_finger_link"/>
    <axis xyz="0 0 1"/>
  </joint>
  <!-- Right finger -->
  <link name="right_gripper_right_finger_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
