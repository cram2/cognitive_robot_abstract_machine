  </link>
  <joint name="right_kms_mounting_plate_joint" type="fixed">
    <parent link="right_tool0"/>
    <child link="right_kms_mounting_plate"/>
    <origin rpy="0 1.5707963267948966 0" xyz="0 0 0"/>
  </joint>
  <kms_40_xacro parent="right_kms_mounting_plate" prefix="right_kms_">
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </kms_40_xacro>
  <link name="right_adapter">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.01" radius="0.035"/>
      </geometry>
      <material name="Cyan"/>
    </visual>
